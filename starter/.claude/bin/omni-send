#!/usr/bin/env bash
# omni-send — call any model through the OmniRoute gateway (OpenAI-compatible).
#
# Replaces the per-vendor wrappers (ds-send et al): one endpoint, one key,
# every provider selected by the --model string.
#
# Usage:
#   omni-send --model MODEL "<prompt>" [--max-tokens N] [--system "<system>"] [--temperature T]
#   omni-send --model MODEL --from-stdin [...flags...] < prompt.md
#
# --model is REQUIRED. There is no default on purpose: the tier belongs to the
# caller's routing decision (see skills/workflow/model-routing), not to this script.
# Resolve it from the Model roster in the project CLAUDE.md.
#
# Defaults:
#   --max-tokens    65536  (thinking models burn ~24K silently before content;
#                           smaller budgets truncate mid-file — see model-routing)
#   --temperature   (unset — omitted from the request unless you pass it; reasoning
#                   models reject any non-default value, so there is no baked-in default)
#
# Environment:
#   OMNIROUTE_BASE_URL   default http://localhost:20128/v1
#   OMNIROUTE_API_KEY    optional for a local gateway; sent as Bearer when set
#
# Output:
#   Raw JSON (OpenAI format) on stdout. Extract content with:
#     jq -r '.choices[0].message.content'
#   NOTE: the request sets "stream": false explicitly. OmniRoute streams SSE by
#   default even when stream is omitted, which would emit `data: {...}` chunks
#   instead of one JSON object and break every caller's jq path.
#
# Requires: curl, jq
#
# Exit codes:
#   0  HTTP 200, JSON returned on stdout
#   1  user-actionable error (bad args, unreachable gateway, HTTP non-200)
#   2  setup error (curl or jq not installed)

set -euo pipefail

# --- preflight -----------------------------------------------------------

if ! command -v curl >/dev/null 2>&1; then
  echo "omni-send: curl not found on PATH" >&2
  exit 2
fi
if ! command -v jq >/dev/null 2>&1; then
  echo "omni-send: jq not found on PATH" >&2
  exit 2
fi

BASE_URL="${OMNIROUTE_BASE_URL:-http://localhost:20128/v1}"

# --- arg parsing ---------------------------------------------------------

MODEL=""
MAX_TOKENS=65536
TEMPERATURE=""
SYSTEM_PROMPT=""
PROMPT=""
FROM_STDIN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)        MODEL="$2"; shift 2 ;;
    --max-tokens)   MAX_TOKENS="$2"; shift 2 ;;
    --temperature)  TEMPERATURE="$2"; shift 2 ;;
    --system)       SYSTEM_PROMPT="$2"; shift 2 ;;
    --from-stdin)   FROM_STDIN=1; shift ;;
    --help|-h)
      sed -n '2,33p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    --*)
      echo "omni-send: unknown flag $1" >&2
      exit 1
      ;;
    *)
      if [[ -z "$PROMPT" ]]; then PROMPT="$1"
      else echo "omni-send: unexpected positional arg: $1" >&2; exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "omni-send: --model is required (no default by design; see the Model roster in CLAUDE.md)" >&2
  echo "omni-send: list available ids with:  curl -s $BASE_URL/models | jq -r '.data[].id'" >&2
  exit 1
fi

if [[ $FROM_STDIN -eq 1 ]]; then
  PROMPT="$(cat -)"
fi
if [[ -z "$PROMPT" ]]; then
  echo "omni-send: prompt is empty (pass as arg or via --from-stdin)" >&2
  exit 1
fi

# --- build request body --------------------------------------------------

BODY=$(jq -n \
  --arg model "$MODEL" \
  --argjson max_tokens "$MAX_TOKENS" \
  --arg system "$SYSTEM_PROMPT" \
  --arg user "$PROMPT" \
  '{
    model: $model,
    max_tokens: $max_tokens,
    stream: false,
    messages: (if $system == "" then
                 [{role: "user", content: $user}]
               else
                 [{role: "system", content: $system}, {role: "user", content: $user}]
               end)
  }')

# temperature is sent ONLY when explicitly requested. Reasoning models reject any
# non-default value outright ("does not support 0.2 ... only the default (1)"),
# so a baked-in default would make this wrapper fail on a whole model class.
# Set it per-model from PER_MODEL_OVERRIDES in the Model roster instead.
if [[ -n "$TEMPERATURE" ]]; then
  BODY=$(jq --argjson t "$TEMPERATURE" '. + {temperature: $t}' <<<"$BODY")
fi

# --- call the gateway ----------------------------------------------------

CURL_AUTH=()
if [[ -n "${OMNIROUTE_API_KEY:-}" ]]; then
  CURL_AUTH=(-H "Authorization: Bearer $OMNIROUTE_API_KEY")
fi

# Body goes to a temp file and the HTTP code to stdout. Do NOT use
# `-w "%{http_code}" -o >(cat)` — process substitution writes asynchronously, so
# the code and body interleave and the last-3-chars split silently corrupts on
# any response big enough to flush in more than one chunk.
BODY_FILE=$(mktemp)
trap 'rm -f "$BODY_FILE"' EXIT

HTTP_CODE=$(curl -sS \
  -w "%{http_code}" \
  -o "$BODY_FILE" \
  "${CURL_AUTH[@]}" \
  -H "Content-Type: application/json" \
  -d "$BODY" \
  "$BASE_URL/chat/completions") || {
    echo "omni-send: curl failed — is the OmniRoute gateway running at $BASE_URL ?" >&2
    exit 1
  }

JSON_BODY="$(cat "$BODY_FILE")"

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "omni-send: HTTP $HTTP_CODE from OmniRoute (model: $MODEL)" >&2
  echo "$JSON_BODY" >&2
  # A tier that is unavailable must escalate, never silently downgrade —
  # see skills/workflow/model-routing. Do not auto-retry on a weaker model here.
  exit 1
fi

echo "$JSON_BODY"
